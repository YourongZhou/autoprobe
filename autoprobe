#!/usr/bin/env python3

import sys
from autoprobe_config import DEFAULT_URLS, detect_vpn_context, parse_args
from autoprobe_runtime import (
    ClashClient,
    NodeResult,
    build_finalists,
    choose_candidates,
    ensure_curl,
    print_result,
    test_node,
)


def main() -> int:
    """CLI entrypoint: discover candidates, probe finalists, then switch selector."""
    args = parse_args()
    ensure_curl()
    urls = args.urls or DEFAULT_URLS
    client = ClashClient(args.controller, args.secret or None, args.controller_unix or None)
    selector_info = client.get_selector(args.selector)
    original = selector_info.get("now")
    candidates = choose_candidates(selector_info, args.nodes, args.top)
    if not candidates:
        print("No candidate nodes found.", file=sys.stderr)
        return 1

    print(f"Selector: {args.selector}")
    print(f"Original node: {original}")
    print(f"Config: {args.config}")
    print(f"Controller: {args.controller}")
    if args.controller_unix:
        print(f"Controller unix socket: {args.controller_unix}")
    print(f"Proxy: {args.proxy}")
    vpn_details = detect_vpn_context(args.proxy)
    if vpn_details:
        print("Detected VPN/proxy context:")
        for item in vpn_details:
            print(f"  - {item}")
    print("URLs:")
    for url in urls:
        print(f"  - {url}")
    print("Candidates:")
    for node in candidates:
        print(f"  - {node}")
    print()

    print(
        f"Stage 1: parallel delay precheck on {args.delay_url} "
        f"with {args.precheck_workers} workers, timeout {args.delay_timeout_ms}ms"
    )
    finalists, delay_map = build_finalists(
        client=client,
        candidates=candidates,
        delay_url=args.delay_url,
        delay_timeout_ms=args.delay_timeout_ms,
        precheck_workers=args.precheck_workers,
        finalists_count=max(1, args.finalists),
    )
    if not finalists:
        print("No nodes passed the delay precheck.", file=sys.stderr)
        if args.dry_run and original:
            client.set_selector(args.selector, original)
        return 1

    print("\nStage 2 finalists:")
    for node in finalists:
        delay_text = f"{delay_map[node]}ms"
        print(f"  - {node} ({delay_text})")
    print()

    results: list[NodeResult] = []
    try:
        for node in finalists:
            print(f"Testing {node} ...")
            result = test_node(
                client=client,
                selector=args.selector,
                node=node,
                urls=urls,
                attempts=args.attempts,
                timeout=args.timeout,
                proxy=args.proxy,
                switch_delay=args.switch_delay,
                request_delay=args.request_delay,
            )
            result.delay_ms = delay_map.get(node)
            results.append(result)
            print_result(result)
            print()
    finally:
        if args.dry_run and original:
            client.set_selector(args.selector, original)

    ranked = sorted(results, key=lambda item: (-item.success_rate, item.avg_latency, item.name))
    print("Ranking:")
    for idx, item in enumerate(ranked, start=1):
        avg = "n/a" if item.avg_latency == float("inf") else f"{item.avg_latency:.2f}s"
        delay = "n/a" if item.delay_ms is None else f"{item.delay_ms}ms"
        print(f"  {idx}. {item.name}: precheck={delay}, success={item.success_count}/{item.attempt_count}, avg={avg}")

    best = ranked[0]
    if args.dry_run:
        print(f"\nDry run complete. Restored {args.selector} to {original}.")
        return 0

    client.set_selector(args.selector, best.name)
    print(f"\nSwitched {args.selector} to {best.name}.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
